<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CommonGradientAttrs">
        <attr name="background" format="color" />
        <attr name="start_color" format="color" />
        <attr name="center_color" format="color" />
        <attr name="end_color" format="color" />
        <attr name="angle" format="float" />
        <attr name="background_drawable" format="reference" />

        <attr name="border" format="dimension" />
        <attr name="border_color" format="color" />
        <attr name="border_start_color" format="color" />
        <attr name="border_center_color" format="color" />
        <attr name="border_end_color" format="color" />
        <attr name="border_color_angle" format="float" />

        <attr name="radius" format="dimension" />
        <attr name="radius_top_left" format="dimension" />
        <attr name="radius_top_right" format="dimension" />
        <attr name="radius_bottom_right" format="dimension" />
        <attr name="radius_bottom_left" format="dimension" />
    </declare-styleable>

    <declare-styleable name="GTextView">
        <attr name="text_start_color" format="color" />
        <attr name="text_center_color" format="color" />
        <attr name="text_end_color" format="color" />
        <attr name="text_color_angle" format="float" />
        <attr name="text_drawable" format="reference" />
    </declare-styleable>
</resources>